# Copy this file to .env.migration.local before running the legacy post image migration.

APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id
APPWRITE_DATABASE_ID=your_database_id
APPWRITE_API_KEY=your_server_api_key_with_tables_read_write_and_files_read_write

APPWRITE_POSTS_TABLE_ID=posts
APPWRITE_POST_MEDIA_TABLE_ID=postMedia
APPWRITE_STORAGE_ID=your_media_bucket_id
