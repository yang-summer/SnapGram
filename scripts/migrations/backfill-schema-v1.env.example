# Copy this file to .env.migration.local before running the schema v1 backfill.
# Pre-migration only: this script depends on legacy relationship columns that should be removed afterwards.

APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id
APPWRITE_DATABASE_ID=your_database_id
APPWRITE_API_KEY=your_server_api_key_with_tables_read_and_tables_write

APPWRITE_POSTS_TABLE_ID=posts
APPWRITE_SAVES_TABLE_ID=saves
APPWRITE_LIKES_TABLE_ID=likes
