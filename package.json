{
  "name": "snapgram",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "migrate:permissions:dry-run": "node scripts/migrations/backfill-resource-permissions.mjs --dry-run",
    "migrate:permissions:dry-run:skip-files": "node scripts/migrations/backfill-resource-permissions.mjs --dry-run --skip-files",
    "migrate:permissions:run": "node scripts/migrations/backfill-resource-permissions.mjs --run",
    "migrate:permissions:run:skip-files": "node scripts/migrations/backfill-resource-permissions.mjs --run --skip-files",
    "migrate:permissions:verify": "node scripts/migrations/backfill-resource-permissions.mjs --verify",
    "migrate:permissions:verify:skip-files": "node scripts/migrations/backfill-resource-permissions.mjs --verify --skip-files",
    "migrate:schema-v1:dry-run": "node scripts/migrations/backfill-schema-v1.mjs --dry-run",
    "migrate:schema-v1:run": "node scripts/migrations/backfill-schema-v1.mjs --run",
    "migrate:schema-v1:verify": "node scripts/migrations/backfill-schema-v1.mjs --verify",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@react-router/node": "7.12.0",
    "@react-router/serve": "7.12.0",
    "@tanstack/react-query": "^5.90.21",
    "ahooks": "^3.9.7",
    "appwrite": "^23.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "isbot": "^5.1.31",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.71.2",
    "react-icons": "^5.6.0",
    "react-intersection-observer": "^10.0.3",
    "react-router": "7.12.0",
    "shadcn": "^4.0.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@react-router/dev": "7.12.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^22",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "node-appwrite": "^23.1.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
